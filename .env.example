# UniQuake Configuration
# Copy this file to .env and configure for your environment

# Public server IP or hostname (required)
# Note: For SSL/WSS to work properly, use a domain name (e.g., example.com)
# instead of an IP address, as SSL certificates are issued for domain names
HOST_IP=localhost

# Port configurations
MASTER_PORT=27950
CONTENT_PORT=9000
WEB_PORT=8080
MOCK_PORT=8080

# Game server configuration
GAME_SERVER_IP=${HOST_IP}
GAME_SERVER_BASE_PORT=27961

# WebSocket URLs (automatically constructed from HOST_IP and ports)
MASTER_SERVER_WS=ws://${HOST_IP}:${MASTER_PORT}
CONTENT_SERVER_URL=${HOST_IP}:${CONTENT_PORT}

# STUN/TURN configuration  
STUN_PORT=3478
STUN_PORT_SECONDARY=3479
TURN_PORT=3478
TURN_REALM=uniquake.com

# Logging
LOG_LEVEL=info

# SSL/TLS Configuration
# SSL_ENABLED=true  # Set to true to force SSL (optional - auto-detected if certs exist)
# SSL_CERT_PATH=/etc/letsencrypt/live/${HOST_IP}/fullchain.pem
# SSL_KEY_PATH=/etc/letsencrypt/live/${HOST_IP}/privkey.pem
# HTTPS_PORT=443
# HTTP_PORT=80